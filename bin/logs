#!/usr/bin/env bash
# Tail HouseTour containers on the VPS.
# Usage: bin/logs [web|worker|postgres|all]
set -euo pipefail

SERVICE="${1:-web}"
SSH_KEY="${SSH_KEY:-$HOME/.ssh/optimi_github_actions}"
VPS_HOST="${VPS_HOST:?Set VPS_HOST}"
VPS_USER="${VPS_USER:-root}"

ssh -i "$SSH_KEY" "${VPS_USER}@${VPS_HOST}" bash -se <<EOF
set -euo pipefail
cd /opt/housetour
case "${SERVICE}" in
  all) docker compose logs -f --tail=200 ;;
  web|worker|postgres|redis|minio) docker compose logs -f --tail=200 ${SERVICE} ;;
  *) docker logs -f --tail=200 housetour-${SERVICE} ;;
esac
EOF
